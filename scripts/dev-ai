#!/usr/bin/env fish

function usage
    echo "Usage:"
    echo "  dev-ai coder [files...]        # alias for qwen36"
    echo "  dev-ai fast [files...]         # alias for qwen36-fast"
    echo "  dev-ai qwen36 [files...]"
    echo "  dev-ai qwen36-fast [files...]"
    echo "  dev-ai deepseek [files...]"
    echo "  dev-ai planner [files...]      # alias for gemma4-26b"
    echo "  dev-ai gemma4-26b [files...]"
    echo "  dev-ai planner-safe [files...] # alias for gemma4-12b"
    echo "  dev-ai gemma4-12b [files...]"
    echo "  dev-ai status"
    echo "  dev-ai stop"
    echo "  dev-ai logs"
end

set mode $argv[1]
set files $argv[2..-1]

if test -z "$mode"
    usage
    exit 1
end

switch "$mode"
    case status
        llm-status
    case stop
        llm-stop
    case logs
        llm-logs
    case coder
        llm-switch coder; and aider-local $files
    case fast coder-fast
        llm-switch coder-fast; and aider-local $files
    case qwen36
        llm-switch qwen36; and aider-local $files
    case qwen36-fast
        llm-switch qwen36-fast; and aider-local $files
    case deepseek
        llm-switch deepseek; and aider-local $files
    case planner gemma4 gemma4-26b
        llm-switch planner; and aider-local $files
    case planner-safe gemma4-12b
        llm-switch planner-safe; and aider-local $files
    case '*'
        usage
        exit 1
end
