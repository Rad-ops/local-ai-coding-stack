#!/usr/bin/env fish

function usage
    echo "Usage:"
    echo "  dev-ai coder [files...]        # alias for qwen36"
    echo "  dev-ai fast [files...]         # alias for qwen36-fast"
    echo "  dev-ai big [files...]          # alias for qwen36-big"
    echo "  dev-ai qwen36 [files...]"
    echo "  dev-ai qwen36-fast [files...]"
    echo "  dev-ai qwen36-big [files...]"
    echo "  dev-ai deepseek [files...]"
    echo "  dev-ai qwen14 [files...]"
    echo "  dev-ai status"
    echo "  dev-ai stop"
    echo "  dev-ai logs"
end

set mode $argv[1]
set files $argv[2..-1]

if test -z "$mode"
    usage
    exit 1
end

switch "$mode"
    case status
        llm-status
    case stop
        llm-stop
    case logs
        llm-logs
    case coder
        llm-switch coder; and aider-local $files
    case fast coder-fast
        llm-switch coder-fast; and aider-local $files
    case big coder-big
        llm-switch coder-big; and aider-local $files
    case qwen36
        llm-switch qwen36; and aider-local $files
    case qwen36-fast
        llm-switch qwen36-fast; and aider-local $files
    case qwen36-big
        llm-switch qwen36-big; and aider-local $files
    case deepseek
        llm-switch deepseek; and aider-local $files
    case qwen14
        llm-switch qwen14; and aider-local $files
    case '*'
        usage
        exit 1
end
