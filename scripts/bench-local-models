#!/usr/bin/env fish

set OUT "$HOME/local-ai-benchmark-results.csv"

echo "timestamp,model,ctx,cache,batch,ubatch,api_ok,gen_tps,vram_used_mib,ram_used,notes" > $OUT

function get_vram
    nvidia-smi --query-compute-apps=used_memory --format=csv,noheader,nounits | head -n 1
end

function get_ram
    free -h | awk '/Mem:/ {print $3 "/" $2}'
end

function bench_one
    set model_name $argv[1]
    set ctx $argv[2]
    set cache $argv[3]
    set batch $argv[4]
    set ubatch $argv[5]

    echo ""
    echo "============================================================"
    echo "Testing $model_name ctx=$ctx cache=$cache batch=$batch ubatch=$ubatch"
    echo "============================================================"

    llm-switch $model_name $ctx

    sleep 5

    set response (curl -s http://127.0.0.1:8080/v1/chat/completions \
        -H "Content-Type: application/json" \
        -d "{ \"model\": \"local\", \"messages\": [ { \"role\": \"user\", \"content\": \"Write a Python function that reads a JSON file containing a list of users and returns the first user's email. Then briefly explain it.\" } ], \"temperature\": 0.2, \"max_tokens\": 512 }")

    set api_ok "yes"
    echo $response | jq -e '.choices[0].message.content' >/dev/null 2>&1; or set api_ok "no"

    set gen_tps (journalctl --user -u local-llm --since "2 minutes ago" --no-pager | grep "tokens per second" | tail -n 1 | sed -E 's/.* ([0-9]+\.[0-9]+) tokens per second.*/\1/')

    if test -z "$gen_tps"
        set gen_tps "unknown"
    end

    set vram (get_vram)
    if test -z "$vram"
        set vram "unknown"
    end

    set ram (get_ram)

    echo (date --iso-8601=seconds),$model_name,$ctx,$cache,$batch,$ubatch,$api_ok,$gen_tps,$vram,$ram,"" >> $OUT

    echo "api_ok=$api_ok gen_tps=$gen_tps vram_mib=$vram ram=$ram"
end

echo "Benchmark output: $OUT"

bench_one qwen36-fast 32768 q8_0 512 128
bench_one qwen36 131072 q8_0 512 128

bench_one deepseek 8192 q8_0 512 128
bench_one deepseek 16384 q8_0 512 128

bench_one planner 8192 q4_0 256 64
bench_one planner-safe 8192 q4_0 256 64

echo ""
echo "Done. Results:"
cat $OUT
