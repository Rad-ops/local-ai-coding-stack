#!/usr/bin/env fish

set CONFIG "$HOME/.config/local-llm/current-model.env"
set API_URL "http://127.0.0.1:8080/v1/models"

function usage
    echo "Usage:"
    echo "  llm-switch coder        # alias for qwen36"
    echo "  llm-switch coder-fast   # alias for qwen36-fast"
    echo "  llm-switch coder-big    # alias for qwen36-big"
    echo "  llm-switch qwen36"
    echo "  llm-switch qwen36-fast"
    echo "  llm-switch qwen36-big"
    echo "  llm-switch deepseek"
    echo "  llm-switch qwen14"
    echo "  llm-switch <profile> <ctx> <cache> <batch> <ubatch>"
end

function require_file
    set file $argv[1]
    if not test -f "$file"
        echo "ERROR: model file not found: $file" >&2
        exit 1
    end
end

set profile $argv[1]
set override_ctx $argv[2]
set override_cache $argv[3]
set override_batch $argv[4]
set override_ubatch $argv[5]

if test -z "$profile"
    usage
    exit 1
end

set THREADS 16
set N_PREDICT -1
set FIT_TARGET 1536
set PARALLEL 4
set CTX_CHECKPOINTS 0
set SPEC_TYPE none
set SPEC_DRAFT_N_MAX 0
set CACHE_DRAFT q8_0
set TEMP 0.7
set TOP_P 0.8
set TOP_K 20
set MIN_P 0.0
set PRESENCE_PENALTY 1.5
set REPEAT_PENALTY 1.0

switch "$profile"
    case coder qwen36
        set MODEL_NAME "Qwen3.6-35B-A3B"
        set MODEL_PATH "$HOME/ai/models/qwen3.6-35b-a3b-mtp/Qwen3.6-35B-A3B-MTP-UD-Q2_K_XL.gguf"
        set CTX_SIZE 131072
        set N_PREDICT 32768
        set CACHE q8_0
        set BATCH_SIZE 512
        set UBATCH_SIZE 128
        set PARALLEL 1
        set CTX_CHECKPOINTS 64
        set SPEC_TYPE draft-mtp
        set SPEC_DRAFT_N_MAX 2
        set TEMP 0.6
        set TOP_P 0.95
        set PRESENCE_PENALTY 0.0
    case coder-fast fast qwen36-fast
        set MODEL_NAME "Qwen3.6-35B-A3B"
        set MODEL_PATH "$HOME/ai/models/qwen3.6-35b-a3b-mtp/Qwen3.6-35B-A3B-MTP-UD-Q2_K_XL.gguf"
        set CTX_SIZE 32768
        set N_PREDICT 8192
        set CACHE q8_0
        set BATCH_SIZE 512
        set UBATCH_SIZE 128
        set PARALLEL 1
        set CTX_CHECKPOINTS 16
        set SPEC_TYPE draft-mtp
        set SPEC_DRAFT_N_MAX 2
        set TEMP 0.6
        set TOP_P 0.95
        set PRESENCE_PENALTY 0.0
    case coder-big big qwen36-big
        set MODEL_NAME "Qwen3.6-35B-A3B"
        set MODEL_PATH "$HOME/ai/models/qwen3.6-35b-a3b-mtp/Qwen3.6-35B-A3B-MTP-UD-Q2_K_XL.gguf"
        set CTX_SIZE 131072
        set N_PREDICT 32768
        set CACHE q8_0
        set BATCH_SIZE 512
        set UBATCH_SIZE 128
        set PARALLEL 1
        set CTX_CHECKPOINTS 64
        set SPEC_TYPE draft-mtp
        set SPEC_DRAFT_N_MAX 3
        set TEMP 0.6
        set TOP_P 0.95
        set PRESENCE_PENALTY 0.0
    case deepseek
        set MODEL_NAME "DeepSeek-R1-Distill-Qwen-32B"
        set MODEL_PATH "$HOME/ai/models/deepseek-r1-qwen-32b/DeepSeek-R1-Distill-Qwen-32B-Q2_K.gguf"
        set CTX_SIZE 8192
        set N_PREDICT 8192
        set CACHE q4_0
        set BATCH_SIZE 256
        set UBATCH_SIZE 64
        set PARALLEL 1
        set TEMP 0.6
        set TOP_P 0.95
        set PRESENCE_PENALTY 0.0
    case qwen14
        set MODEL_NAME "Qwen3-14B"
        set MODEL_PATH "$HOME/ai/models/qwen3-14b/Qwen3-14B-Q5_K_M.gguf"
        set CTX_SIZE 8192
        set CACHE q8_0
        set BATCH_SIZE 512
        set UBATCH_SIZE 128
    case '*'
        usage
        exit 1
end

if test -n "$override_ctx"
    set CTX_SIZE "$override_ctx"
end
if test -n "$override_cache"
    set CACHE "$override_cache"
end
if test -n "$override_batch"
    set BATCH_SIZE "$override_batch"
end
if test -n "$override_ubatch"
    set UBATCH_SIZE "$override_ubatch"
end

require_file "$MODEL_PATH"
mkdir -p (dirname "$CONFIG")

printf "MODEL_PATH=%s\nCTX_SIZE=%s\nN_PREDICT=%s\nTHREADS=%s\nBATCH_SIZE=%s\nUBATCH_SIZE=%s\nCACHE_TYPE_K=%s\nCACHE_TYPE_V=%s\nCACHE_TYPE_K_DRAFT=%s\nCACHE_TYPE_V_DRAFT=%s\nFIT_TARGET=%s\nPARALLEL=%s\nCTX_CHECKPOINTS=%s\nSPEC_TYPE=%s\nSPEC_DRAFT_N_MAX=%s\nTEMP=%s\nTOP_P=%s\nTOP_K=%s\nMIN_P=%s\nPRESENCE_PENALTY=%s\nREPEAT_PENALTY=%s\n" \
    "$MODEL_PATH" "$CTX_SIZE" "$N_PREDICT" "$THREADS" "$BATCH_SIZE" "$UBATCH_SIZE" "$CACHE" "$CACHE" "$CACHE_DRAFT" "$CACHE_DRAFT" "$FIT_TARGET" "$PARALLEL" "$CTX_CHECKPOINTS" "$SPEC_TYPE" "$SPEC_DRAFT_N_MAX" "$TEMP" "$TOP_P" "$TOP_K" "$MIN_P" "$PRESENCE_PENALTY" "$REPEAT_PENALTY" > "$CONFIG"

echo "Switching local LLM:"
echo "  Profile: $profile"
echo "  Model:   $MODEL_NAME"
echo "  Path:    $MODEL_PATH"
echo "  Context: $CTX_SIZE"
echo "  Cache:   $CACHE"
echo "  Batch:   $BATCH_SIZE"
echo "  uBatch:  $UBATCH_SIZE"
echo "  Spec:    $SPEC_TYPE"

systemctl --user restart local-llm
if test $status -ne 0
    echo "ERROR: failed to restart local-llm" >&2
    exit 1
end

echo "Waiting for API: $API_URL"
for i in (seq 1 180)
    if curl -fsS "$API_URL" >/dev/null 2>&1
        echo "Ready."
        echo "GPU memory:"
        nvidia-smi --query-gpu=name,memory.used,memory.total,utilization.gpu --format=csv,noheader,nounits
        exit 0
    end
    sleep 1
end

echo "ERROR: server did not become ready within 180 seconds." >&2
echo "Try: llm-logs" >&2
exit 1
